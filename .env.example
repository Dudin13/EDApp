# EDudin Configuration
# Copy this to .env and adjust as needed

# Base Paths
DATA_DIR="data"
ASSETS_DIR="assets"
OUTPUT_DIR="app/output"

# Model Names (should be in ASSETS_DIR/weights)
PLAYER_MODEL="detect_players.pt"
BALL_MODEL="detect_ball.pt"
PITCH_MODEL="pose_field.pt"

# ML Parameters
DETECTION_CONF=0.35
TRACKING_BUFFER=30
BATCH_SIZE=1

# Execution
DEVICE="cuda" # use 'cpu' if no GPU is available
